uci set network.network1=interface
uci set network.network1.proto='static'
uci set network.network1.device='br-network1'
uci set network.network1.ipaddr='172.16.81.1'
uci set network.network1.netmask='255.255.255.0'
uci add_list network.network1.dns='8.8.8.8'
uci add_list network.network1.dns='8.8.4.4'
uci commit network 

uci add network device
uci set network.@device[-1].name='br-network1'
uci set network.@device[-1].type='bridge'
uci commit network

uci add firewall zone
uci set firewall.@zone[-1]=zone                                                                             
uci set firewall.@zone[-1].name="network1"                                                         
uci set firewall.@zone[-1].input='ACCEPT'                                                                   
uci set firewall.@zone[-1].output='ACCEPT'                                                                  
uci set firewall.@zone[-1].network="network1"                                                        
uci set firewall.@zone[-1].forward='ACCEPT'                                                                 
uci commit firewall 
                      
uci add firewall forwarding                                                                                       
uci set firewall.@forwarding[-1]=forwarding                                                                 
uci set firewall.@forwarding[-1].src="network1"                                                      
uci set firewall.@forwarding[-1].dest='wan'                                                                                                                                                                     
uci commit firewall 

