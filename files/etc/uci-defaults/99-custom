if [ "$(cat /tmp/sysinfo/model)" = "YunCore AX835" ]; then
    uci set wireless.radio0.htmode='HE40'
    uci set wireless.radio1.htmode='HE160'
    uci set wireless.radio1.channel='52'
else
    uci set wireless.radio0.htmode='HE80'
    uci set wireless.radio1.htmode='HE40'
    uci set wireless.radio1.channel='36'
fi
uci commit wireless


uci set wireless.radio0.channel='1'
uci set wireless.radio0.noscan='1'
uci commit wireless

uci set wireless.captive_radio0=wifi-iface
uci set wireless.captive_radio0.device='radio0'
uci set wireless.captive_radio0.network='network1'
uci set wireless.captive_radio0.mode='ap'
uci set wireless.captive_radio0.ssid='MrWiFi-Open'
